{
  "name": "videoclip",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Client-side video clipper: trim videos from Google Drive or local files into looping GIFs / MP4s entirely in the browser.",
  "scripts": {
    "copy-ffmpeg": "node scripts/copy-ffmpeg.mjs",
    "postinstall": "node scripts/copy-ffmpeg.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/core-mt": "^0.12.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
